{
  "name": "code-research-agent-frontend",
  "version": "1.3.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit && tsc -p tsconfig.node.json --noEmit",
