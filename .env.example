IMAGE_GENERATION_TIMEOUT_SECONDS=60
IMAGE_GENERATION_MAX_RETRIES=0
IMAGE_GENERATION_MAX_CONCURRENCY=1
IMAGE_GENERATION_MAX_SINGLE_IMAGE_BYTES=10485760
IMAGE_GENERATION_MAX_WIDTH=1536
IMAGE_GENERATION_MAX_HEIGHT=1536
IMAGE_GENERATION_CACHE_ENABLED=true
IMAGE_GENERATION_CACHE_PATH=data/image_generation_cache.sqlite3
IMAGE_GENERATION_CACHE_ASSET_ROOT=data/image_generation_cache
IMAGE_GENERATION_PROMPT_VERSION=1.3.3
IMAGE_GENERATION_SCHEMA_VERSION=1.3.3
TEACHING_DIAGRAM_FONT_PATH=
TEACHING_DIAGRAM_FONT_NAME=
TEACHING_REVIEW_CACHE_ENABLED=true
