OUTPUT_ROOT=outputs
LOG_LEVEL=INFO
LIBRARY_DB_PATH=data/python_function_library.sqlite3
ANALYSIS_MODE=rule
TEXT_LLM_ENABLED=false
TEACHING_NARRATIVE_LLM_ENABLED=false
VISION_VLM_ENABLED=false

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=45
DEEPSEEK_MAX_RETRIES=1
DEEPSEEK_MAX_OUTPUT_TOKENS=1200

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TIMEOUT_SECONDS=45
QWEN_MAX_RETRIES=1
QWEN_MAX_OUTPUT_TOKENS=1200

# Group-level LLM defaults are kept for compatibility; provider-specific variables above take precedence.
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=1
LLM_MAX_INPUT_CHARS=12000
LLM_MAX_OUTPUT_TOKENS=1200
LLM_MAX_FUNCTION_EXPLANATIONS=20
LLM_MAX_FILE_EXPLANATIONS=10
LLM_MAX_MODEL_EXPLANATIONS=5
LLM_MAX_PAPER_ALIGNMENTS=5
LLM_MAX_TOTAL_ENTITIES=30
LLM_MAX_PROVIDER_REQUESTS=60
LLM_MAX_CONCURRENCY=2
LLM_CACHE_ENABLED=true
LLM_CACHE_PATH=data/llm_explanation_cache.sqlite3

QWEN_VL_API_KEY=
QWEN_VL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-plus
QWEN_VL_TIMEOUT_SECONDS=45
QWEN_VL_MAX_RETRIES=1
QWEN_VL_MAX_OUTPUT_TOKENS=1200
QWEN_VL_SUPPORTS_JSON_OBJECT=false
QWEN_VL_DISABLE_THINKING=false

GLM_V_API_KEY=
GLM_V_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_V_MODEL=glm-4.5v
GLM_V_TIMEOUT_SECONDS=45
GLM_V_MAX_RETRIES=1
GLM_V_MAX_OUTPUT_TOKENS=1200
GLM_V_SUPPORTS_JSON_OBJECT=false
GLM_V_DISABLE_THINKING=false

# Group-level VLM defaults are kept for compatibility; provider-specific variables above take precedence.
VLM_TIMEOUT_SECONDS=45
VLM_MAX_RETRIES=1
VLM_MAX_FIGURE_ANALYSES=5
VLM_MAX_PROVIDER_REQUESTS=10
VLM_MAX_CONCURRENCY=2
VLM_MAX_SINGLE_IMAGE_BYTES=10485760
VLM_MAX_TOTAL_IMAGE_BYTES=31457280
VLM_MAX_IMAGE_WIDTH=4096
VLM_MAX_IMAGE_HEIGHT=4096
VLM_MAX_OUTPUT_TOKENS=1200
VLM_CACHE_ENABLED=true
VLM_CACHE_PATH=data/vlm_figure_cache.sqlite3
VLM_PROMPT_VERSION=1.2.0
VLM_SCHEMA_VERSION=1.2.3

IMAGE_GENERATION_ENABLED=false
TEACHING_REVIEW_VLM_ENABLED=false
EXTERNAL_TEACHING_REVIEW_CONSENT=false
QWEN_IMAGE_API_KEY=
QWEN_IMAGE_BASE_URL=https://dashscope.aliyuncs.com
QWEN_IMAGE_ENDPOINT_PATH=/api/v1/services/aigc/multimodal-generation/generation
QWEN_IMAGE_WORKSPACE=
QWEN_IMAGE_SUPPORTS_ASYNC=false
QWEN_IMAGE_MODEL=
QWEN_IMAGE_TIMEOUT_SECONDS=60
QWEN_IMAGE_MAX_RETRIES=0
QWEN_IMAGE_REQUEST_WIDTH=1280
QWEN_IMAGE_REQUEST_HEIGHT=720
QWEN_IMAGE_ALLOWED_DOMAINS=dashscope.aliyuncs.com,aliyuncs.com,oss-cn-hangzhou.aliyuncs.com,oss-cn-beijing.aliyuncs.com,oss-cn-shanghai.aliyuncs.com,oss-cn-shenzhen.aliyuncs.com
SEEDREAM_API_KEY=
SEEDREAM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_ENDPOINT_PATH=/images/generations
SEEDREAM_SUPPORTS_ASYNC=false
SEEDREAM_MODEL=
SEEDREAM_TIMEOUT_SECONDS=60
SEEDREAM_MAX_RETRIES=0
SEEDREAM_REQUEST_WIDTH=1280
SEEDREAM_REQUEST_HEIGHT=720
SEEDREAM_ALLOWED_DOMAINS=ark.cn-beijing.volces.com
