# Deprecated v1 compatibility only
#
# v2 does not use this file as an installation or deployment prerequisite.
# Select a strict YAML configuration explicitly:
#
#   cra serve --config config/local-cpu.yaml
#   cra serve --config config/team-autodl-gpu.yaml
#
# Store Provider credentials with `cra secrets set`; never commit API keys.
# The variables below are accepted only while migrating an older v1 install and
# emit a deprecation warning when they override YAML. Remove them after migration.

# OUTPUT_ROOT=outputs
# LIBRARY_DB_PATH=data/python_function_library.sqlite3
# STRUCTURED_INDEX_ENABLED=true
# RETRIEVAL_MODEL_CACHE_DIR=data/models
# OBSERVABILITY_ENABLED=true
# OBSERVABILITY_API_ENABLED=true
# EVALUATION_API_ENABLED=true
# LOCAL_ARTIFACT_ROOT=data/artifacts
# CODE_RESEARCH_AGENT_SECRET_STORE_PATH=~/.coderesearch_agent/secrets.json

# Do not place DEEPSEEK_API_KEY, QWEN_API_KEY, database passwords, signing keys,
# bootstrap tokens, MinIO credentials, Redis passwords, or OIDC secrets here.
