# IMAGE_TASK_MAX_POLL_ATTEMPTS=45

# Local provider settings center. Writes are local-only unless explicitly enabled.
CODE_RESEARCH_AGENT_SECRET_STORE_PATH=~/.coderesearch_agent/secrets.json
REMOTE_PROVIDER_SETTINGS_ENABLED=false
PROVIDER_SETTINGS_ADMIN_TOKEN=
PROVIDER_SETTINGS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PROVIDER_SETTINGS_RATE_LIMIT_PER_MINUTE=60

ZIP_MAX_FILE_BYTES=104857600
PAPER_MAX_FILE_BYTES=52428800
PAPER_MAX_PAGES=100
PAPER_MAX_TEXT_CHARS=2000000
PAPER_PARSE_TIMEOUT_SECONDS=60
PAPER_MAX_IMAGE_OBJECTS=500
PAPER_MAX_FIGURE_CANDIDATES=50
PAPER_MAX_ORIGINAL_ASSET_BYTES=104857600
PAPER_MAX_SINGLE_ASSET_BYTES=20971520
PAPER_MAX_RENDER_PIXELS=16000000
PAPER_MAX_DRAWING_PATHS_PER_PAGE=5000
PAPER_EXTRACTION_TIMEOUT_SECONDS=60
PAPER_FIGURE_RENDER_DPI=144
